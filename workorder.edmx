<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
    <edmx:Include Alias="Common" Namespace="com.sap.vocabularies.Common.v1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Core.V1.xml">
    <edmx:Include Alias="Core" Namespace="Org.OData.Core.V1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Validation.V1.xml">
    <edmx:Include Alias="Validation" Namespace="Org.OData.Validation.V1"/>
  </edmx:Reference>
  <edmx:DataServices>
    <Schema Namespace="WorkOrderService" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <Annotation Term="Core.Links">
        <Collection>
          <Record>
            <PropertyValue Property="rel" String="author"/>
            <PropertyValue Property="href" String="https://cap.cloud.sap"/>
          </Record>
        </Collection>
      </Annotation>
      <EntityContainer Name="EntityContainer">
        <EntitySet Name="WorkOrders" EntityType="WorkOrderService.WorkOrders"/>
        <EntitySet Name="StatusHistory" EntityType="WorkOrderService.StatusHistory"/>
        <ActionImport Name="assignTechnician" Action="WorkOrderService.assignTechnician"/>
        <ActionImport Name="updateStatus" Action="WorkOrderService.updateStatus"/>
        <ActionImport Name="startWork" Action="WorkOrderService.startWork"/>
        <ActionImport Name="completeWork" Action="WorkOrderService.completeWork"/>
      </EntityContainer>
      <EntityType Name="WorkOrders">
        <Key>
          <PropertyRef Name="ID"/>
        </Key>
        <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
        <Property Name="WorkOrderNo" Type="Edm.String" MaxLength="20"/>
        <Property Name="EquipmentID" Type="Edm.String" MaxLength="30"/>
        <Property Name="EquipmentName" Type="Edm.String" MaxLength="100"/>
        <Property Name="ProcedureID" Type="Edm.String" MaxLength="30"/>
        <Property Name="MaintenanceType" Type="Edm.String" MaxLength="40"/>
        <Property Name="ProcedureName" Type="Edm.String" MaxLength="100"/>
        <Property Name="AssignedTo" Type="Edm.String" MaxLength="50"/>
        <Property Name="AssignedName" Type="Edm.String" MaxLength="100"/>
        <Property Name="Priority" Type="Edm.String" MaxLength="20"/>
        <Property Name="Description" Type="Edm.String" MaxLength="500"/>
        <Property Name="Status" Type="Edm.String"/>
        <Property Name="CreatedBy" Type="Edm.String" MaxLength="50"/>
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" Precision="7"/>
        <Property Name="DueDate" Type="Edm.Date"/>
      </EntityType>
      <EntityType Name="StatusHistory">
        <Key>
          <PropertyRef Name="ID"/>
        </Key>
        <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
        <Property Name="WorkOrderNo" Type="Edm.String" MaxLength="20"/>
        <Property Name="OldStatus" Type="Edm.String" MaxLength="30"/>
        <Property Name="NewStatus" Type="Edm.String" MaxLength="30"/>
        <Property Name="ChangedBy" Type="Edm.String" MaxLength="50"/>
        <Property Name="ChangedAt" Type="Edm.DateTimeOffset" Precision="7"/>
      </EntityType>
      <Action Name="assignTechnician" IsBound="false">
        <Parameter Name="workOrderNo" Type="Edm.String"/>
        <Parameter Name="technicianId" Type="Edm.String"/>
        <Parameter Name="technicianName" Type="Edm.String"/>
      </Action>
      <Action Name="updateStatus" IsBound="false">
        <Parameter Name="workOrderNo" Type="Edm.String"/>
        <Parameter Name="status" Type="Edm.String"/>
      </Action>
      <Action Name="startWork" IsBound="false">
        <Parameter Name="workOrderNo" Type="Edm.String"/>
      </Action>
      <Action Name="completeWork" IsBound="false">
        <Parameter Name="workOrderNo" Type="Edm.String"/>
      </Action>
      <Annotations Target="WorkOrderService.WorkOrders/ID">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="WorkOrderService.WorkOrders/Status">
        <Annotation Term="Validation.AllowedValues">
          <Collection>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Open"/>
              <PropertyValue Property="Value" String="Open"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Created"/>
              <PropertyValue Property="Value" String="Created"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Assigned"/>
              <PropertyValue Property="Value" String="Assigned"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="InProgress"/>
              <PropertyValue Property="Value" String="InProgress"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Completed"/>
              <PropertyValue Property="Value" String="Completed"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Closed"/>
              <PropertyValue Property="Value" String="Closed"/>
            </Record>
            <Record Type="Validation.AllowedValue">
              <Annotation Term="Core.SymbolicName" String="Cancelled"/>
              <PropertyValue Property="Value" String="Cancelled"/>
            </Record>
          </Collection>
        </Annotation>
      </Annotations>
      <Annotations Target="WorkOrderService.StatusHistory/ID">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>