{
	"_version": "1.85.0",
	"sap.app": {
		"id": "maintenance.workorder.workorder",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				"",
				"en"
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:lrop",
			"version": "1.25.0",
			"toolsId": "541e9a93-ece2-4b90-98dd-212abd364439"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/work-order/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.148.1",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.templates": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "maintenance.workorder.workorder.i18n.i18n",
					"supportedLocales": [
						"",
						"en"
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						"",
						"en"
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"extends": {
			"extensions": {
				"sap.ui.controllerExtensions": {
					"sap.fe.templates.ListReport.ListReportController": {
						"controllerName": "maintenance.workorder.workorder.ext.controller.ListReportExt"
					}
				}
			}
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"pattern": ":?query:",
					"name": "WorkOrdersList",
					"target": "WorkOrdersList"
				},
				{
					"pattern": "WorkOrders({key}):?query:",
					"name": "WorkOrdersObjectPage",
					"target": "WorkOrdersObjectPage"
				}
			],
			"targets": {
				"WorkOrdersList": {
					"type": "Component",
					"id": "WorkOrdersList",
					"name": "sap.fe.templates.ListReport",
					"options": {
						"settings": {
							"contextPath": "/WorkOrders",
							"variantManagement": "Page",
							"navigation": {
								"WorkOrders": {
									"detail": {
										"route": "WorkOrdersObjectPage"
									}
								}
							},
							"controlConfiguration": {
								"@com.sap.vocabularies.UI.v1.LineItem": {
									"tableSettings": {
										"type": "ResponsiveTable"
									},
									"columns": {
										"TechnicianActions": {
											"header": "Actions",
											"template": "maintenance.workorder.workorder.ext.fragment.TechnicianActions",
											"position": {
												"placement": "After",
												"anchor": "DataField::Status"
											}
										}
									}
								}
							}
						}
					}
				},
				"WorkOrdersObjectPage": {
					"type": "Component",
					"id": "WorkOrdersObjectPage",
					"name": "sap.fe.templates.ObjectPage",
					"options": {
						"settings": {
							"editableHeaderContent": false,
							"contextPath": "/WorkOrders"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fiori": {
		"registrationIds": [],
		"archeType": "transactional"
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	}
}