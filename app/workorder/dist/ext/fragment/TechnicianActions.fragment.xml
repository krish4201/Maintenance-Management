<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <HBox renderType="Bare" alignItems="Center">
    <Button
      text="Start Work"
      type="Emphasized"
      visible="false"
      press=".extension.maintenance.workorder.workorder.ext.controller.ListReportExt.onStartWork" />
    <Button
      text="Complete Task"
      visible="false"
      press=".extension.maintenance.workorder.workorder.ext.controller.ListReportExt.onCompleteWork" />
    <Button
      text="View Procedure"
      visible="{role>/technician}"
      press=".extension.maintenance.workorder.workorder.ext.controller.ListReportExt.onViewProcedure" />
  </HBox>
</core:FragmentDefinition>
