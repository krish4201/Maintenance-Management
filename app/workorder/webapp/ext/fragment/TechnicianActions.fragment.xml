<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <HBox
    renderType="Bare"
    alignItems="Center"
    core:require="{StatusFormatter: 'maintenance/workorder/workorder/ext/model/StatusFormatter'}">
    <Button
      text="Start Work"
      type="Emphasized"
      visible="{ parts: [{ path: 'Status' }, { path: 'role>/technician' }], formatter: 'StatusFormatter.isStartVisible' }"
      press=".extension.maintenance.workorder.workorder.ext.controller.ListReportExt.onStartWork" />
    <Button
      text="Complete Task"
      visible="{ parts: [{ path: 'Status' }, { path: 'role>/technician' }], formatter: 'StatusFormatter.isCompleteVisible' }"
      press=".extension.maintenance.workorder.workorder.ext.controller.ListReportExt.onCompleteWork" />
    <Button
      text="View Procedure"
      visible="{role>/technician}"
      press=".extension.maintenance.workorder.workorder.ext.controller.ListReportExt.onViewProcedure" />
  </HBox>
</core:FragmentDefinition>
