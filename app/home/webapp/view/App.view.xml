<mvc:View
  controllerName="maintenance.home.controller.App"
  displayBlock="true"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:viz="sap.viz.ui5.controls"
  xmlns:viz.data="sap.viz.ui5.data"
  xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
  <App>
    <Page
      title="Dashboard"
      busy="{home>/loading}"
      class="homePage">
      <!-- <headerContent>
        <Button
          text="{home>/name} - {home>/role}"
          type="Emphasized"
          icon="sap-icon://person-placeholder"
          enabled="false" />
      </headerContent> -->
      <content>
        <MessageStrip
          text="{home>/error}"
          type="Error"
          showIcon="true"
          visible="{= !!${home>/error} }"
          class="sapUiSmallMargin" />

        <VBox
          visible="{home>/supervisor}"
          class="homeContent">
          <VBox class="heroBand">
            <HBox class="heroHeader" alignItems="Center" justifyContent="SpaceBetween">
              <VBox>
                <Title text="Supervisor Home" level="H2" />
                <Text text="Work order health, priorities, and equipment coverage" class="heroSubtitle" />
              </VBox>
              <HBox class="heroActions">
                <Button
                  text="Assign Technician"
                  type="Emphasized"
                  icon="sap-icon://employee-approvals"
                  press=".onAssignTechnician" />
              </HBox>
            </HBox>
          </VBox>

          <FlexBox
            class="linkGrid"
            wrap="Wrap"
            renderType="Bare">
            <GenericTile
              header="Work Orders"
              subheader="View and assign work"
              press=".onOpenWorkOrders">
              <TileContent>
                <NumericContent icon="sap-icon://activity-items" value="{home>/summary/totalWorkOrders}" />
              </TileContent>
            </GenericTile>
            <GenericTile
              header="Unassigned"
              subheader="Work orders waiting for technician"
              press=".onAssignTechnician">
              <TileContent>
                <NumericContent icon="sap-icon://employee-approvals" value="{home>/summary/unassignedOrders}" />
              </TileContent>
            </GenericTile>
            <GenericTile
              header="View Equipment"
              subheader="Open master equipment"
              press=".onOpenEquipment">
              <TileContent>
                <NumericContent icon="sap-icon://machine" value="{home>/summary/equipmentCount}" />
              </TileContent>
            </GenericTile>
            <GenericTile
              header="View Procedures"
              subheader="Open procedure list"
              press=".onShowUniqueProcedures">
              <TileContent>
                <NumericContent icon="sap-icon://list" value="{home>/summary/procedureCount}" />
              </TileContent>
            </GenericTile>
          </FlexBox>

          <FlexBox
            class="chartGrid sapUiMediumMarginTop"
            wrap="Wrap"
            renderType="Bare">
            <VBox class="chartPanel">
              <Title text="Work Orders by Assigned" level="H3" class="panelTitle" />
              <viz:VizFrame
                id="assignedChart"
                width="100%"
                height="350px"
                vizType="donut"
                uiConfig="{applicationSet:'fiori'}">
                <viz:dataset>
                  <viz.data:FlattenedDataset data="{home>/assignedChart}">
                    <viz.data:dimensions>
                      <viz.data:DimensionDefinition name="Assigned" value="{home>label}" />
                    </viz.data:dimensions>
                    <viz.data:measures>
                      <viz.data:MeasureDefinition name="Orders" value="{home>value}" />
                    </viz.data:measures>
                  </viz.data:FlattenedDataset>
                </viz:dataset>
                <viz:feeds>
                  <viz.feeds:FeedItem uid="size" type="Measure" values="Orders" />
                  <viz.feeds:FeedItem uid="color" type="Dimension" values="Assigned" />
                </viz:feeds>
              </viz:VizFrame>
            </VBox>

            <VBox class="chartPanel">
              <Title text="Work Orders by Status" level="H3" class="panelTitle" />
              <viz:VizFrame
                id="statusChart"
                width="100%"
                height="350px"
                vizType="column"
                uiConfig="{applicationSet:'fiori'}">
                <viz:dataset>
                  <viz.data:FlattenedDataset data="{home>/statusChart}">
                    <viz.data:dimensions>
                      <viz.data:DimensionDefinition name="Status" value="{home>label}" />
                    </viz.data:dimensions>
                    <viz.data:measures>
                      <viz.data:MeasureDefinition name="Orders" value="{home>value}" />
                    </viz.data:measures>
                  </viz.data:FlattenedDataset>
                </viz:dataset>
                <viz:feeds>
                  <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Orders" />
                  <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Status" />
                </viz:feeds>
              </viz:VizFrame>
            </VBox>
          </FlexBox>
        </VBox>

        <VBox
          visible="{home>/planner}"
          class="homeContent">
          <VBox class="heroBand">
            <HBox class="heroHeader" alignItems="Center" justifyContent="SpaceBetween">
              <VBox>
                <Title text="Planner Workspace" level="H2" />
                <Text text="Create work orders and review equipment context" class="heroSubtitle" />
              </VBox>
              <HBox class="heroActions">
                <Button
                  text="Create Work Order"
                  type="Emphasized"
                  icon="sap-icon://add"
                  press=".onCreateWorkOrder" />
                <Button
                  text="Create Equipment"
                  icon="sap-icon://machine"
                  press=".onCreateEquipment" />
                <Button
                  text="Create Procedure"
                  icon="sap-icon://list"
                  press=".onCreateProcedure" />
              </HBox>
            </HBox>
          </VBox>
          <FlexBox class="linkGrid" wrap="Wrap" renderType="Bare">
            <GenericTile
              header="Work Orders"
              subheader="Create and review maintenance work"
              press=".onOpenWorkOrders">
              <TileContent>
                <NumericContent icon="sap-icon://activity-items" value="{home>/summary/totalWorkOrders}" />
              </TileContent>
            </GenericTile>
            <GenericTile
              header="Master Equipment"
              subheader="Review equipment master data"
              press=".onOpenEquipment">
              <TileContent>
                <NumericContent icon="sap-icon://machine" value="{home>/summary/equipmentCount}" />
              </TileContent>
            </GenericTile>
            <GenericTile
              header="Procedures"
              subheader="Create and review procedure data"
              press=".onShowUniqueProcedures">
              <TileContent>
                <NumericContent icon="sap-icon://list" value="{home>/summary/procedureCount}" />
              </TileContent>
            </GenericTile>
          </FlexBox>
        </VBox>

        <VBox
          visible="{home>/technician}"
          class="homeContent technicianPanel">
          <VBox class="heroBand">
            <HBox class="heroHeader" alignItems="Center" justifyContent="SpaceBetween">
              <VBox>
                <Title text="Technician Workspace" level="H2" />
                <Text text="Work orders and procedures assigned to you" class="heroSubtitle" />
              </VBox>
            </HBox>
            <VBox class="workSelector">
              <Label text="Assigned Work Order" />
              <ComboBox selectedKey="{home>/selectedWorkOrder}" width="100%" items="{home>/workOrders}">
                <core:Item key="{home>WorkOrderNo}" text="{home>WorkOrderNo} - {home>EquipmentName} ({home>Status})" />
              </ComboBox>
            </VBox>
          </VBox>
          <FlexBox class="linkGrid" wrap="Wrap" renderType="Bare">
            <GenericTile
              header="Assigned to Me"
              subheader="Open my work order list"
              press=".onOpenWorkOrders">
              <TileContent>
                <NumericContent icon="sap-icon://employee-approvals" value="{home>/assignedCount}" />
              </TileContent>
            </GenericTile>
            <GenericTile
              header="Procedure List"
              subheader="Show procedures for my orders"
              press=".onShowProcedures">
              <TileContent>
                <NumericContent icon="sap-icon://list" value="{home>/technicianProcedureCount}" />
              </TileContent>
            </GenericTile>
          </FlexBox>
        </VBox>
      </content>
      <dependents>
        <Dialog
          id="createWorkOrderDialog"
          title="Create Work Order"
          contentWidth="34rem">
          <content>
            <VBox class="createForm">
              <Label text="Equipment ID" required="true" />
              <ComboBox
                selectedKey="{home>/create/EquipmentID}"
                width="100%"
                items="{home>/equipments}"
                selectionChange=".onEquipmentSelected">
                <core:Item key="{home>equipment_id}" text="{home>equipment_id} - {home>equipment_name}" />
              </ComboBox>

              <Label text="Equipment Name" required="true" />
              <Input value="{home>/create/EquipmentName}" enabled="false" />

              <Label text="Procedure ID" required="true" />
              <Input value="{home>/create/ProcedureID}" enabled="false" />

              <Label text="Maintenance Type" required="true" />
              <Select selectedKey="{home>/create/MaintenanceType}" width="100%" change=".onMaintenanceTypeChanged">
                <core:Item key="Preventive Maintenance" text="Preventive Maintenance" />
                <core:Item key="Breakdown Maintenance" text="Breakdown Maintenance" />
              </Select>

              <Label text="Priority" required="true" />
              <Select selectedKey="{home>/create/Priority}" width="100%">
                <core:Item key="Low" text="Low" />
                <core:Item key="Medium" text="Medium" />
                <core:Item key="High" text="High" />
                <core:Item key="Critical" text="Critical" />
              </Select>

              <Label text="Status" />
              <Input value="{home>/create/Status}" enabled="false" />

            </VBox>
          </content>
          <beginButton>
            <Button text="Create" type="Emphasized" icon="sap-icon://accept" press=".onSubmitWorkOrder" />
          </beginButton>
          <endButton>
            <Button text="Cancel" press=".onCancelCreateWorkOrder" />
          </endButton>
        </Dialog>
        <Dialog
          id="assignTechnicianDialog"
          title="Assign Technician"
          contentWidth="34rem">
          <content>
            <VBox class="createForm">
              <Label text="Work Order" required="true" />
              <ComboBox selectedKey="{home>/assign/WorkOrderNo}" width="100%" items="{home>/workOrders}">
                <core:Item key="{home>WorkOrderNo}" text="{home>WorkOrderNo} - {home>EquipmentName}" />
              </ComboBox>

              <Label text="Technician" required="true" />
              <ComboBox selectedKey="{home>/assign/TechnicianId}" width="100%" items="{home>/technicians}" selectionChange=".onTechnicianSelected">
                <core:Item key="{home>userId}" text="{home>userId} - {home>userName}" />
              </ComboBox>
            </VBox>
          </content>
          <beginButton>
            <Button text="Assign" type="Emphasized" icon="sap-icon://accept" press=".onSubmitAssignTechnician" />
          </beginButton>
          <endButton>
            <Button text="Cancel" press=".onCancelAssignTechnician" />
          </endButton>
        </Dialog>
        <Dialog
          id="createProcedureDialog"
          title="Create Procedure"
          contentWidth="34rem">
          <content>
            <VBox class="createForm">
              <Label text="Equipment ID" required="true" />
              <ComboBox
                selectedKey="{home>/createProcedure/EquipmentID}"
                width="100%"
                items="{home>/equipments}"
                selectionChange=".onProcedureEquipmentSelected">
                <core:Item key="{home>equipment_id}" text="{home>equipment_id} - {home>equipment_name}" />
              </ComboBox>

              <Label text="Equipment Name" />
              <Input value="{home>/createProcedure/EquipmentName}" enabled="false" />

              <Label text="Equipment Type" />
              <Input value="{home>/createProcedure/EquipmentType}" enabled="false" />

              <Label text="Maintenance Category" required="true" />
              <Select selectedKey="{home>/createProcedure/MaintenanceCategory}" width="100%">
                <core:Item key="Preventive Maintenance" text="Preventive Maintenance" />
                <core:Item key="Breakdown Maintenance" text="Breakdown Maintenance" />
              </Select>

              <Label text="Maintenance Procedure" required="true" />
              <TextArea
                value="{home>/createProcedure/MaintenanceProcedure}"
                rows="5"
                width="100%"
                maxLength="255" />
            </VBox>
          </content>
          <beginButton>
            <Button text="Create" type="Emphasized" icon="sap-icon://accept" press=".onSubmitProcedure" />
          </beginButton>
          <endButton>
            <Button text="Cancel" press=".onCancelCreateProcedure" />
          </endButton>
        </Dialog>
        <Dialog
          id="createEquipmentDialog"
          title="Create Equipment"
          contentWidth="34rem">
          <content>
            <VBox class="createForm">
              <Label text="Equipment ID" required="true" />
              <Input value="{home>/createEquipment/equipment_id}" maxLength="20" />

              <Label text="Equipment Name" required="true" />
              <Input value="{home>/createEquipment/equipment_name}" maxLength="100" />

              <Label text="Equipment Type" required="true" />
              <Input value="{home>/createEquipment/equipment_type}" maxLength="50" />

              <Label text="Manufacturer" />
              <Input value="{home>/createEquipment/manufacturer}" maxLength="100" />

              <Label text="Model Number" />
              <Input value="{home>/createEquipment/model_number}" maxLength="50" />

              <Label text="Serial Number" />
              <Input value="{home>/createEquipment/serial_number}" maxLength="50" />

              <Label text="Location" />
              <Input value="{home>/createEquipment/location}" maxLength="100" />

              <!-- <Label text="Last Maintained By" />
              <Input value="{home>/createEquipment/last_maintained_by}" maxLength="100" /> -->
              

              <Label text="Status" required="true" />
              <Select selectedKey="{home>/createEquipment/status}" width="100%">
                <core:Item key="Active" text="Active" />
                <core:Item key="Inactive" text="Inactive" />
                <core:Item key="Maintenance" text="Maintenance" />
              </Select>
            </VBox>
          </content>
          <beginButton>
            <Button text="Create" type="Emphasized" icon="sap-icon://accept" press=".onSubmitEquipment" />
          </beginButton>
          <endButton>
            <Button text="Cancel" press=".onCancelCreateEquipment" />
          </endButton>
        </Dialog>
        <Dialog
          id="procedureListDialog"
          title="Procedure List"
          contentWidth="42rem">
          <content>
            <List items="{home>/procedureList}">
              <StandardListItem
                title="{home>ProcedureID} - {home>EquipmentName}"
                description="{home>MaintenanceProcedure}"
                info="{home>MaintenanceType}" />
            </List>
          </content>
          <endButton>
            <Button text="Close" press=".onCloseProcedures" />
          </endButton>
        </Dialog>
      </dependents>
    </Page>
  </App>
</mvc:View>
